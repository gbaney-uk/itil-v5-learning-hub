:root {
  --primary: #102a5c;
  --primary-light: #1f5fa8;
  --secondary: #eef4fb;
  --accent: #d34242;
  --orange: #f47b20;
  --green: #158f6a;
  --blue: #1769c2;
  --purple: #7248c8;
  --teal: #139aa0;
  --red: #e22c3a;
  --yellow: #f5a700;
  --pink: #df2d7f;
  --grey: #67758a;
  --light: #f6f8fb;
  --text: #24313a;
  --muted: #5f6c7b;
  --border: #d7e0ea;
  --card: #ffffff;
  --shadow: 0 8px 22px rgba(17, 24, 39, 0.08);
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  font-family: Arial, Helvetica, sans-serif;
  background: var(--light);
  color: var(--text);
  line-height: 1.5;
}

.app-header {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: white;
  padding: 34px 20px;
  text-align: center;
}

.header-content {
  max-width: 1100px;
  margin: 0 auto;
}

.eyebrow {
  margin: 0 0 8px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-size: 0.8rem;
  font-weight: bold;
}

.app-header h1 {
  margin: 0 0 10px;
  font-size: 2.2rem;
}

.app-header p {
  margin: 0;
  font-size: 1rem;
}

.top-nav {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  gap: 10px;
  justify-content: center;
  flex-wrap: wrap;
  padding: 12px;
  background: white;
  border-bottom: 1px solid var(--border);
  box-shadow: 0 3px 10px rgba(17, 24, 39, 0.05);
}

.top-nav button {
  border: none;
  background: var(--primary);
  color: white;
  padding: 10px 14px;
  border-radius: 999px;
  cursor: pointer;
  font-weight: bold;
}

.top-nav button:hover {
  background: var(--primary-light);
}

main {
  max-width: 1450px;
  margin: 0 auto;
  padding: 22px;
}

.panel,
.mindmap-panel {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 24px;
  margin-bottom: 28px;
  box-shadow: var(--shadow);
}

.section-heading,
.map-title {
  margin-bottom: 18px;
}

.section-heading h2,
.map-title h2 {
  margin: 0 0 6px;
  color: var(--primary);
  font-size: 1.7rem;
}

.section-heading p,
.map-title p {
  margin: 0;
  color: var(--muted);
}

.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(160px, 1fr));
  gap: 16px;
  margin-bottom: 18px;
}

.stat-card {
  background: var(--secondary);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 20px;
  text-align: center;
}

.stat-number {
  display: block;
  font-size: 2.1rem;
  font-weight: bold;
  color: var(--primary);
}

.stat-label {
  display: block;
  margin-top: 6px;
  color: var(--muted);
}

.progress-list {
  display: grid;
  gap: 10px;
}

.progress-check {
  display: block;
  background: #fff8e6;
  border: 1px solid #f1d99a;
  padding: 14px;
  border-radius: 12px;
  font-weight: bold;
}

.progress-check input {
  margin-right: 8px;
  transform: scale(1.1);
}

.mindmap-layout {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  align-items: stretch;
}

.centre-card {
  grid-column: 1 / -1;
  background: linear-gradient(135deg, #e60073, #d0005c);
  color: white;
  border-radius: 18px;
  padding: 24px;
  text-align: center;
  box-shadow: 0 6px 18px rgba(208, 0, 92, 0.22);
}

.centre-card h3 {
  margin: 0 0 12px;
  font-size: 2rem;
}

.centre-card p {
  max-width: 850px;
  margin: 10px auto 0;
  font-size: 1.05rem;
}

.map-card {
  background: white;
  border: 2px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
}

.map-card h3 {
  margin: 0;
  color: white;
  padding: 11px 14px;
  font-size: 1.05rem;
}

.map-card p,
.map-card ul,
.map-card ol {
  margin: 14px;
}

.map-card ul,
.map-card ol {
  padding-left: 24px;
}

.map-card li {
  margin-bottom: 7px;
}

.map-card.blue {
  border-color: var(--blue);
}

.map-card.blue h3 {
  background: var(--blue);
}

.map-card.orange {
  border-color: var(--orange);
}

.map-card.orange h3 {
  background: var(--orange);
}

.map-card.purple {
  border-color: var(--purple);
}

.map-card.purple h3 {
  background: var(--purple);
}

.map-card.red {
  border-color: var(--red);
}

.map-card.red h3 {
  background: var(--red);
}

.map-card.teal {
  border-color: var(--teal);
}

.map-card.teal h3 {
  background: var(--teal);
}

.map-card.green {
  border-color: var(--green);
}

.map-card.green h3 {
  background: var(--green);
}

.map-card.yellow {
  border-color: var(--yellow);
}

.map-card.yellow h3 {
  background: var(--yellow);
}

.map-card.grey {
  border-color: var(--grey);
}

.map-card.grey h3 {
  background: var(--grey);
}

.map-card.pink {
  border-color: var(--pink);
}

.map-card.pink h3 {
  background: var(--pink);
}

.wide-card {
  grid-column: span 2;
}

.support-strip {
  margin-top: 18px;
  padding: 14px;
  border: 1px solid #9bbce5;
  background: #edf5ff;
  border-radius: 12px;
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  align-items: center;
}

.support-strip span {
  background: white;
  border: 1px solid #c9d9ee;
  padding: 6px 10px;
  border-radius: 999px;
}

.exam-strip {
  margin-top: 14px;
  background: #092653;
  color: white;
  border-radius: 12px;
  padding: 16px;
}

.exam-strip h3 {
  margin: 0 0 8px;
  font-size: 1.25rem;
}

.exam-strip ul {
  margin: 0;
  padding-left: 22px;
}

.question-card {
  background: var(--secondary);
  border-radius: 14px;
  padding: 18px;
  border: 1px solid var(--border);
  margin-bottom: 14px;
}

.question-card h3 {
  margin: 0 0 8px;
  color: var(--primary);
}

.answer-button {
  background: var(--accent);
  color: white;
  border: none;
  padding: 10px 14px;
  border-radius: 999px;
  cursor: pointer;
  font-weight: bold;
}

.answer-button:hover {
  background: #aa3030;
}

.answer {
  margin-top: 14px;
  background: white;
  border-left: 5px solid var(--accent);
  padding: 14px;
  border-radius: 10px;
}

.hidden {
  display: none;
}

.app-footer {
  text-align: center;
  padding: 20px;
  color: var(--muted);
}

@media (max-width: 1100px) {
  .mindmap-layout {
    grid-template-columns: repeat(2, 1fr);
  }

  .wide-card {
    grid-column: span 2;
  }
}

@media (max-width: 760px) {
  .app-header h1 {
    font-size: 1.6rem;
  }

  main {
    padding: 14px;
  }

  .panel,
  .mindmap-panel {
    padding: 18px;
  }

  .dashboard-grid,
  .mindmap-layout {
    grid-template-columns: 1fr;
  }

  .centre-card {
    grid-column: auto;
  }

  .wide-card {
    grid-column: auto;
  }

  .top-nav {
    justify-content: flex-start;
    overflow-x: auto;
    flex-wrap: nowrap;
  }

  .top-nav button {
    white-space: nowrap;
  }
}
